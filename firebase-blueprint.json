{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Premium user data for EASY MODE™",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "SavedPrompt": {
      "title": "Saved Prompt",
      "description": "A prompt saved by a user for quick access",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "promptId": { "type": "string" },
        "title": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "promptId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/saved_prompts/{savedPromptId}": {
      "schema": "SavedPrompt",
      "description": "User's collection of saved prompts"
    }
  }
}
